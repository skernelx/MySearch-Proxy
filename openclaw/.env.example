# MySearch OpenClaw Skill
# 最小可用配置先填 Tavily + Firecrawl。
# X / Social 是可选增强项，不填也能用于 web / docs / extract / research。

MYSEARCH_NAME=MySearch
MYSEARCH_TIMEOUT_SECONDS=45

# Tavily
MYSEARCH_TAVILY_BASE_URL=https://api.tavily.com
MYSEARCH_TAVILY_SEARCH_PATH=/search
MYSEARCH_TAVILY_EXTRACT_PATH=/extract
MYSEARCH_TAVILY_AUTH_MODE=body
MYSEARCH_TAVILY_AUTH_HEADER=Authorization
MYSEARCH_TAVILY_AUTH_SCHEME=Bearer
MYSEARCH_TAVILY_AUTH_FIELD=api_key
MYSEARCH_TAVILY_API_KEY=
MYSEARCH_TAVILY_API_KEYS=
MYSEARCH_TAVILY_KEYS_FILE=

# Firecrawl
MYSEARCH_FIRECRAWL_BASE_URL=https://api.firecrawl.dev
MYSEARCH_FIRECRAWL_SEARCH_PATH=/v2/search
MYSEARCH_FIRECRAWL_SCRAPE_PATH=/v2/scrape
MYSEARCH_FIRECRAWL_AUTH_MODE=bearer
MYSEARCH_FIRECRAWL_AUTH_HEADER=Authorization
MYSEARCH_FIRECRAWL_AUTH_SCHEME=Bearer
MYSEARCH_FIRECRAWL_AUTH_FIELD=api_key
MYSEARCH_FIRECRAWL_API_KEY=
MYSEARCH_FIRECRAWL_API_KEYS=
MYSEARCH_FIRECRAWL_KEYS_FILE=

# xAI / X search（可选）
MYSEARCH_XAI_BASE_URL=https://api.x.ai/v1
MYSEARCH_XAI_RESPONSES_PATH=/responses
MYSEARCH_XAI_SEARCH_MODE=official
MYSEARCH_XAI_SOCIAL_BASE_URL=
MYSEARCH_XAI_SOCIAL_SEARCH_PATH=/social/search
MYSEARCH_XAI_AUTH_MODE=bearer
MYSEARCH_XAI_AUTH_HEADER=Authorization
MYSEARCH_XAI_AUTH_SCHEME=Bearer
MYSEARCH_XAI_AUTH_FIELD=api_key
MYSEARCH_XAI_API_KEY=
MYSEARCH_XAI_API_KEYS=
MYSEARCH_XAI_KEYS_FILE=
MYSEARCH_XAI_MODEL=grok-4.20-beta-latest-non-reasoning

# compatible 模式示例：
# MYSEARCH_XAI_BASE_URL=https://media.example.com/v1
# MYSEARCH_XAI_SOCIAL_BASE_URL=https://your-social-gateway.example.com
# MYSEARCH_XAI_SEARCH_MODE=compatible
# MYSEARCH_XAI_API_KEY=your-gateway-token

